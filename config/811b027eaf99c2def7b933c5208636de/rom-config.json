{
  "name": "Super Mario Bros",
  "mapper": 0,
  "watches": [
    { "address": "0x000E", "name": "playerState", "description": "Player state (0=loading, 1=alive, 2=dead, 3=entering_pipe, 6=climbing, 7=entering_area, 8=normal)" },
    { "address": "0x0700", "name": "gameMode", "description": "Game mode (0=title, 1=playing, 2=victory)" },
    { "address": "0x0747", "name": "areaType", "description": "Area type (0=water, 1=ground, 2=underground, 3=castle)" },
    { "address": "0x075F", "name": "areaIndex", "description": "Area progression index (0=1-1, 1=1-2, 2=1-3, 3=1-4, 4=2-1, ...)" },
    { "address": "0x0770", "name": "screenPage", "description": "Screen left page location" }
  ],
  "saveState": {
    "keyTemplate": "save-{world}-{level}-{areaType}",
    "reads": [
      { "address": "0x075F", "token": "world", "transform": "divFloor4Add1" },
      { "address": "0x075F", "token": "level", "transform": "mod4Add1" },
      { "address": "0x0747", "token": "areaType" }
    ]
  },
  "events": [
    {
      "name": "pipeEntry",
      "label": "Mario entered a pipe",
      "trigger": { "watch": "playerState", "equals": 3 }
    }
  ]
}
